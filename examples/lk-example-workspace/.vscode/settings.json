{
    // Enable semantic highlighting for LKR
    "editor.semanticHighlighting.enabled": true,
    
    // LKR Language Server settings
    "lk.lsp.enabled": true,
    "lk.lsp.autoStart": true,
    "lk.lsp.serverPath": "~/proj/lk/target/debug/lkr-lsp",
    "lk.lsp.semanticTokens.enabled": true,
    "lk.lsp.semanticTokens.throttleMs": 100,
    "lk.lsp.inlayHints.enabled": false,
    
    // Enable verbose logging for debugging (optional)
    // "lk.lsp.trace": "verbose",
    // "lk.lsp.outputChannel.enabled": true,
}