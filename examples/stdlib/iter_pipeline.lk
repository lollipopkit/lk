// Iterator and stream pipeline demo

import iter;

fn assert(cond) {
  if (!cond) { panic("assertion failed"); }
}

// 1. iter.range — generate number sequences
let r1 = iter.range(5);        // [0,1,2,3,4]
assert(r1 == [0, 1, 2, 3, 4]);

let r2 = iter.range(2, 6);     // [2,3,4,5]
assert(r2 == [2, 3, 4, 5]);

let r3 = iter.range(0, 10, 2); // [0,2,4,6,8]
assert(r3 == [0, 2, 4, 6, 8]);

// 2. iter module functions vs method sugar
let xs = [1, 2, 3, 4, 5];

// Both styles work:
let m1 = iter.map(xs, |x| x * 3);        // module style
let m2 = xs.map(|x| x * 3);              // method sugar
assert(m1 == m2);
assert(m1 == [3, 6, 9, 12, 15]);

let f1 = iter.filter(xs, |x| x > 3);
let f2 = xs.filter(|x| x > 3);
assert(f1 == f2);
assert(f1 == [4, 5]);

// 3. enumerate — index + value pairs
let indexed = iter.enumerate(["a", "b", "c"]);
assert(indexed == [[0, "a"], [1, "b"], [2, "c"]]);

// 4. zip — pair elements from two lists
let zipped = iter.zip([1, 2, 3], ["x", "y"]);
assert(zipped == [[1, "x"], [2, "y"]]);

// 5. take / skip via iter module
let taken = iter.take(xs, 3);
assert(taken == [1, 2, 3]);
let skipped = iter.skip(xs, 3);
assert(skipped == [4, 5]);

// 6. chain — concatenate two lists
let chained = iter.chain([1, 2], [3, 4]);
assert(chained == [1, 2, 3, 4]);

// 7. flatten — one-level deep
let flat = iter.flatten([[1, 2], [3], [4, 5]]);
assert(flat == [1, 2, 3, 4, 5]);

// 8. unique — deduplicate
let uniq = iter.unique([3, 1, 4, 1, 5, 9, 2, 6, 5]);
assert(uniq == [3, 1, 4, 5, 9, 2, 6]);

// 9. chunk — split into groups
let chunks = iter.chunk([1, 2, 3, 4, 5], 2);
assert(chunks.len() == 3);

// 10. Pipeline: generate → filter → map → reduce
let pipeline = iter.range(1, 20)
  .filter(|x| x % 2 == 0)
  .map(|x| x * x)
  .reduce(0, |acc, x| acc + x);
// Even squares 1..19: 4+16+36+64+100+144+196+256+324 = 1140
assert(pipeline == 1140);

println("iter_pipeline: all assertions passed");