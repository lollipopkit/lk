// Bench: List operations — push, iterate, map
import time;

let iters = 10000;
let t0 = time.now();
for _ in 1..=iters {
    let list = [];
    for i in 1..=100 {
        list.push(i);
    }
    let sum = 0;
    for v in list {
        sum += v;
    }
}
let t1 = time.now();
println("list_ops: iters=${iters}, elapsed=${t1 - t0}ms");