{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LKR",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#struct-definition"
    },
    {
      "include": "#impl-definition"
    },
    {
      "include": "#closures"
    },
    {
      "include": "#number-literal"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#ident-access"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lkr",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.lkr"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.lkr"
            }
          }
        },
        {
          "name": "comment.line.double-slash.lkr",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.lkr"
            }
          },
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lkr",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lkr",
              "match": "\\\\[nrt\\\\\\\"'$0bf]"
            },
            {
              "name": "meta.interpolation.lkr",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.begin.lkr"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.end.lkr"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.lkr",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.lkr",
              "match": "\\\\[nrt\\\\'$0bf]"
            },
            {
              "name": "meta.interpolation.lkr",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.begin.lkr"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.end.lkr"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.backtick.lkr",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.interpolation.lkr",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.begin.lkr"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.interpolation.end.lkr"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            },
            {
              "name": "constant.character.escape.lkr",
              "match": "\\\\[`$\\\\nrtbf]"
            }
          ]
        },
        {
          "name": "string.raw.lkr",
          "begin": "(r)(#*)(\\\")",
          "beginCaptures": {
            "1": {
              "name": "storage.type.string.lkr"
            },
            "2": {
              "name": "punctuation.definition.string.begin.lkr"
            },
            "3": {
              "name": "punctuation.definition.string.begin.lkr"
            }
          },
          "end": "(\\\")(\\\\2)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.lkr"
            },
            "2": {
              "name": "punctuation.definition.string.end.lkr"
            }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.definition.lkr",
          "begin": "\\b(fn)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.lkr"
            }
          },
          "end": "(?=\\{)",
          "patterns": [
            {
              "name": "entity.name.function.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "include": "#function-params-inner"
            },
            {
              "include": "#types"
            },
            {
              "name": "keyword.operator.arrow.lkr",
              "match": "->"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "function-params-inner": {
      "patterns": [
        {
          "name": "meta.function.parameters.lkr",
          "begin": "\\(",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.parens.lkr"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parens.lkr"
            }
          },
          "patterns": [
            {
              "include": "#named-params-block"
            },
            {
              "name": "variable.parameter.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.key-value.lkr",
              "match": ":(?=\\s)"
            },
            {
              "name": "keyword.operator.assignment.lkr",
              "match": "=(?!=)"
            },
            {
              "include": "#types"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "named-params-block": {
      "patterns": [
        {
          "name": "meta.named-parameters.lkr",
          "begin": "\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.braces.begin.lkr"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.braces.end.lkr"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.named.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.key-value.lkr",
              "match": ":(?=\\s)"
            },
            {
              "name": "keyword.operator.assignment.lkr",
              "match": "=(?!=)"
            },
            {
              "include": "#types"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "struct-definition": {
      "patterns": [
        {
          "name": "meta.struct.definition.lkr",
          "begin": "\\b(struct)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.struct.lkr"
            }
          },
          "end": "(?<=\\})",
          "patterns": [
            {
              "name": "entity.name.type.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
            },
            {
              "name": "meta.struct.body.lkr",
              "begin": "\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.braces.begin.lkr"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.braces.end.lkr"
                }
              },
              "patterns": [
                {
                  "name": "variable.other.member.lkr",
                  "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
                },
                {
                  "name": "punctuation.separator.key-value.lkr",
                  "match": ":(?=\\s)"
                },
                {
                  "include": "#types"
                },
                {
                  "include": "#punctuation"
                }
              ]
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "impl-definition": {
      "patterns": [
        {
          "name": "meta.impl.definition.lkr",
          "begin": "\\b(impl)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.impl.lkr"
            }
          },
          "end": "(?<=\\})",
          "patterns": [
            {
              "name": "keyword.other.for.lkr",
              "match": "\\bfor\\b"
            },
            {
              "name": "entity.name.type.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
            },
            {
              "include": "#function-definition"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "closures": {
      "patterns": [
        {
          "name": "meta.closure.lkr",
          "begin": "(?<=(?:^|[\\s,;(=\\[{=:!&|+\\-*/<>]))\\|(?!\\|)",
          "end": "\\|",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.closure.begin.lkr"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.closure.end.lkr"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.lkr",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.lkr",
              "match": ","
            }
          ]
        }
      ]
    },
    "number-literal": {
      "patterns": [
        {
          "name": "constant.numeric.float.lkr",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.lkr",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.lkr",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.lkr",
          "match": "\\b(Int|Float|String|Bool|Nil|Any|List|Map|Task|Channel)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lkr",
          "match": "\\b(if|else|while|for|in|match|case|default|select|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.lkr",
          "match": "\\b(let|const|fn|struct|type|trait|impl|import|from|as)\\b"
        },
        {
          "name": "keyword.other.lkr",
          "match": "\\b(spawn|chan|send|recv)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.lkr",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.lkr",
          "match": "(\\|\\||&&)"
        },
        {
          "name": "keyword.operator.nullish-coalescing.lkr",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chaining.lkr",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.channel.lkr",
          "match": "<-"
        },
        {
          "name": "keyword.operator.arrow.lkr",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.range.lkr",
          "match": "\\.\\.(=)?"
        },
        {
          "name": "keyword.operator.assignment.lkr",
          "match": ":=|\\+=|-=|\\*=|/=|%=|(?<![!=<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.lkr",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.unary.not.lkr",
          "match": "!(?!=)"
        },
        {
          "name": "keyword.operator.ternary.lkr",
          "match": "\\?(?![.?])"
        }
      ]
    },
    "ident-access": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.lkr"
            }
          }
        },
        {
          "name": "variable.other.member.lkr",
          "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.semicolon.lkr",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.lkr",
          "match": ","
        },
        {
          "name": "punctuation.section.braces.lkr",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.lkr",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.lkr",
          "match": "[()]"
        }
      ]
    }
  },
  "scopeName": "source.lkr"
}
