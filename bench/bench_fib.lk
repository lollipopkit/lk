// Bench: Iterative Fibonacci
import time;

fn iterative(n) {
    if n <= 1 { return n; }
    let a = 0;
    let b = 1;
    for _ in 2..=n {
        let t = a + b;
        a = b;
        b = t;
    }
    return b;
}

let iters = 50000;
let n = 30;
let t0 = time.now();
let acc = 0;
for _ in 1..=iters {
    acc = iterative(n);
}
let t1 = time.now();
let elapsed = t1 - t0;
println("fib_iterative: fib(${n}) = ${acc}, iters=${iters}, elapsed=${elapsed}ms");