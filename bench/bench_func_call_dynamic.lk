// Bench: function call overhead with runtime-known argument
import time;

fn add(a, b) { return a + b; }

let seed = time.now();
let iters = 100000 + (seed - seed);
let step = 1 + (seed - seed);
let acc = 0;

let t0 = time.now();
for _ in 1..=iters {
    acc = add(acc, step);
}
let t1 = time.now();

println("func_call_dynamic: iters=${iters}, acc=${acc}, elapsed=${t1 - t0}ms");
