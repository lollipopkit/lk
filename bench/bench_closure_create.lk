// Bench: Closure creation plus one call per closure
import time;

fn make_adder(n) { return |x| x + n; }

let iters = 100000;
let t0 = time.now();
let acc = 0;
for i in 1..=iters {
    let adder = make_adder(i);
    acc = adder(acc);
}
let t1 = time.now();
println("closure_create: iters=${iters}, acc=${acc}, elapsed=${t1 - t0}ms");
