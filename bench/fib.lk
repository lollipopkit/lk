import os;

// Fibonacci benchmark (iterative)
fn fibonacci(n) {
    if (n <= 1) { return n; }
    let a = 0;
    let b = 1;
    for _ in 2..=n {
        let t = a + b;
        a = b;
        b = t;
    }
    return b;
}

let start = os.clock();
let result = 0;
let i = 0;
while (i < 100000) {
    result = fibonacci(30);
    i = i + 1;
}
let elapsed = os.clock() - start;
println("lk fib30 x100k: result={}, time={}s", result, elapsed);