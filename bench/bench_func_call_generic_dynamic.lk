// Bench: generic dynamic function calls that should not match tiny-call fusion
import os;

fn mix(a, b, c) {
    return (((a * 3) + (b % 11)) + (c * 5)) % 1000000007;
}

let seed = os.epoch();
let iters = 100000 + (seed - seed);
let acc = 1;

let t0 = os.clock();
for i in 1..=iters {
    acc = mix(acc, i, i % 17);
}
let t1 = os.clock();

println("func_call_generic_dynamic: iters=${iters}, acc=${acc}, elapsed=${(t1 - t0) * 1000}ms");
