// Bench: Closure / lambda call overhead
import time;

fn make_adder(n) { return |x| x + n; }

let adder = make_adder(1);
let iters = 100000;
let t0 = time.now();
let acc = 0;
for _ in 1..=iters {
    acc = adder(acc);
}
let t1 = time.now();
println("closure_call: iters=${iters}, acc=${acc}, elapsed=${t1 - t0}ms");