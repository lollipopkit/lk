// Bench: Create no-capture closure and call it once per loop
import time;

let iters = 100000;
let t0 = time.now();
let acc = 0;
for _ in 1..=iters {
    let inc = |x| x + 1;
    acc = inc(acc);
}
let t1 = time.now();
println("closure_create_no_capture: iters=${iters}, acc=${acc}, elapsed=${t1 - t0}ms");
