// Bench: dynamic function calls with per-iteration changing arguments
import os;

fn mix(a, b) {
    return (a + b) % 1000000007;
}

let seed = os.epoch();
let iters = 100000 + (seed - seed);
let acc = 0;

let t0 = os.clock();
for i in 1..=iters {
    acc = mix(acc, i % 7);
}
let t1 = os.clock();

println("func_call_varying_dynamic: iters=${iters}, acc=${acc}, elapsed=${(t1 - t0) * 1000}ms");
