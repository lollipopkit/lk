// List operations benchmark
let start = os.clock();
let t = [];
let i = 0;
while (i < 100000) {
    t.push(i * 2);
    i = i + 1;
}
let sum = 0;
let j = 0;
while (j < t.len()) {
    sum = sum + t[j];
    j = j + 1;
}
let elapsed = os.clock() - start;
println("lkr list 100k: sum={}, time={:.4}s", sum, elapsed);