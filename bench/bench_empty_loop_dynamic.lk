// Bench: dynamic counted loop with consumed result
import time;

let seed = time.now();
let iters = 1000000 + (seed - seed);
let count = 0;

let t0 = time.now();
for _ in 1..=iters {
    count += 1;
}
let t1 = time.now();

println("empty_loop_dynamic: iters=${iters}, count=${count}, elapsed=${t1 - t0}ms");
