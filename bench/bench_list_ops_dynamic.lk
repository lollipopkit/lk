// Bench: list operations with consumed result
import time;

let seed = time.now();
let iters = 10000 + (seed - seed);
let width = 100 + (seed - seed);
let total = 0;

let t0 = time.now();
for _ in 1..=iters {
    let list = [];
    for i in 1..=width {
        list.push(i);
    }
    let sum = 0;
    for v in list {
        sum += v;
    }
    total += sum;
}
let t1 = time.now();

println("list_ops_dynamic: iters=${iters}, total=${total}, elapsed=${t1 - t0}ms");
