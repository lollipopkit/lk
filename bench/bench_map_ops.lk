// Bench: Map operations — create, set, iterate values
import time;

let iters = 10000;
let t0 = time.now();
for _ in 1..=iters {
    let m = {};
    for i in 1..=50 {
        m.set("key${i}", i * 2);
    }
    let sum = 0;
    for v in m.values() {
        sum += v;
    }
}
let t1 = time.now();
println("map_ops: iters=${iters}, elapsed=${t1 - t0}ms");